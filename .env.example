# Copy to .env at repo root and fill in RPC_URLS before running.
# All other values are sensible defaults for Polygon.

# Mongo
MONGO_URL=mongodb://mongo:27017
MONGO_DB_NAME=fee-collector

# Indexer (Polygon defaults)
CHAIN_ID=137
CHAIN_NAME=polygon
# Comma-separated list of RPC endpoints. The indexer wraps these in an
# ethers v5 FallbackProvider. Provide at least one, two or three recommended.
RPC_URLS=https://polygon-rpc.com,https://rpc.ankr.com/polygon
CONTRACT_ADDRESS=0xbD6C7B0d2f68c2b7805d88388319cfB6EcB50eA9
START_BLOCK=78600000
# finalized: query eth_getBlockByNumber('finalized'). Recommended for Polygon
# post-Rio and for Ethereum.
# confirmations: use latestBlock - CONFIRMATION_DEPTH. Fallback for chains
# that do not expose the finalized tag.
FINALITY_STRATEGY=finalized
CONFIRMATION_DEPTH=64
POLL_INTERVAL_MS=2000
INITIAL_CHUNK_SIZE=2000
MIN_CHUNK_SIZE=50
MAX_CHUNK_SIZE=5000
MAX_RETRIES=5
HEALTH_PORT=9090

# API
API_PORT=3000

# Logging
LOG_LEVEL=info
NODE_ENV=development
